{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "URL to user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "GeneratedPost": {
      "title": "Generated Post",
      "description": "A post generated by the AI and saved by the user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who saved the post." },
        "topic": { "type": "string", "description": "The original topic prompt." },
        "platform": { "type": "string", "description": "Target platform." },
        "tone": { "type": "string", "description": "The tone of the post." },
        "language": { "type": "string", "description": "Target language." },
        "post": { "type": "string", "description": "The generated post text." },
        "nativeHashtags": { "type": "array", "items": { "type": "string" }, "description": "Hashtags in native language." },
        "englishHashtags": { "type": "array", "items": { "type": "string" }, "description": "Hashtags in English." },
        "imageUrl": { "type": "string", "description": "URL of the generated image (if any)." },
        "imageUrls": { "type": "array", "items": { "type": "string" }, "description": "List of generated image URLs." },
        "videoUrl": { "type": "string", "description": "URL of the generated video (if any)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the post was saved." }
      },
      "required": ["userId", "post", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/posts/{postId}": {
      "schema": "GeneratedPost",
      "description": "Saved AI generated posts."
    },
    "/history/{historyId}": {
      "schema": "GeneratedPost",
      "description": "Automatic history of all generated posts."
    }
  }
}
